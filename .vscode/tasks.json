{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build current file",
            "command": "g++",
            "args": [
                "-g",
                "-Wall",
                "-std=c++17",
                "${file}",                          // 当前打开的文件
                "-o",
                "${workspaceFolder}\\${fileBasenameNoExtension}.exe"  // 同名 exe
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}